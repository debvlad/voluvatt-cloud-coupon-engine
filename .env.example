# Frontend/public values. These are safe only when RLS is enabled.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY
PUBLIC_APP_URL=https://your-cloudflare-pages-url.pages.dev
VITE_PUBLIC_APP_URL=http://localhost:5173

# Supabase Edge Functions secrets. Do NOT put the service role key in frontend hosting.
# Set these via: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY
PUBLIC_APP_URL=https://your-cloudflare-pages-url.pages.dev
